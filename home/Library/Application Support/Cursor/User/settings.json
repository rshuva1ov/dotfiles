{
  "files.autoSave": "afterDelay",
  "editor.tabSize": 2,
  "explorer.confirmDelete": false,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.singleQuote": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint",
  },
  "[markdown]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.defaultFoldingRangeProvider": "dbaeumer.vscode-eslint",
  "security.workspace.trust.untrustedFiles": "open",
  "editor.minimap.enabled": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.iconTheme": "vscode-icons",
  "vsicons.dontShowNewVersionMessage": true,
  "editor.fontSize": 16,
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.fontFamily": "MesloLGS NF, Symbols Nerd Font Mono, monospace",
  "[typescriptreact]": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.tabCompletion": "on",
  "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe",
      ],
      "args": [],
      "icon": "terminal-cmd",
    },
    "Git Bash": {
      "source": "Git Bash",
    },
    "kali-linux (WSL)": {
      "path": "C:\\Windows\\System32\\wsl.exe",
      "args": ["-d", "kali-linux"],
      "icon": "terminal-linux",
    },
  },
  "[xml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
  },
  "editor.formatOnType": true,
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "workbench.startupEditor": "none",
  "editor.inlineSuggest.showToolbar": "always",
  "workbench.colorTheme": "Default Dark Modern",
  "cursor.cpp.enablePartialAccepts": true,
  "typescript.suggest.completeFunctionCalls": true,
  "cursor.general.disableHttp2": true,
  "[plaintext]": {
    "editor.defaultFormatter": "lkrms.inifmt",
  },
  "[ignore]": {
    "editor.defaultFormatter": "lkrms.inifmt",
  },
  "[properties]": {
    "editor.defaultFormatter": "lkrms.inifmt",
  },
  "javascript.updateImportsOnFileMove.enabled": "never",
  "typescript.experimental.useTsgo": true,
  "window.autoDetectColorScheme": false,
  "workbench.settings.applyToAllProfiles": [
    "editor.fontFamily",
    "editor.fontSize",
    "cursor.composer.textSizeScale",
  ],
  "cursor.inlineDiff.enablePerformanceProtection": false,
}
