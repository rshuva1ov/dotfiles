.DS_Store
*.zwc
.zcompdump*
.zsh_history

# Oh My Zsh — данные установки (не в репозитории)
home/.config/zsh/oh-my-zsh/

# Сторонние темы и плагины — ставятся через scripts/install-zsh-from-github.sh
home/.config/zsh/oh-my-zsh-custom/plugins/zsh-autosuggestions/
home/.config/zsh/oh-my-zsh-custom/plugins/zsh-syntax-highlighting/
home/.config/zsh/oh-my-zsh-custom/themes/powerlevel10k/
*.swp
*.tmp
Thumbs.db

# Кэши и машинно-специфичное (не коммитить)
**/globalStorage/
**/workspaceStorage/
**/History/
**/CachedData/
**/Crashpad/
**/GPUCache/
**/Code Cache/

# Вложенные git в клонах плагинов (если появятся снова)
**/.git/
